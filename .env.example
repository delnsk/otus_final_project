# RAG MCP — copy to .env and adjust.
# Local: pydantic-settings reads this file (python -m rag_mcp).
# Docker: compose substitutes ${VAR} from project-root .env (optional; defaults in docker-compose.yml).

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=phi3:mini

# Embeddings: chroma (default, no Ollama) | ollama
EMBEDDING_PROVIDER=chroma
EMBEDDING_MODEL=nomic-embed-text

# Storage & chunking
CHROMA_PATH=./data/chroma
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# Retrieval & Corrective RAG
TOP_K=5
RRF_K=60
GRADE_RELEVANCE_THRESHOLD=3
MAX_BROADEN_LOOPS=2

# Logging
LOG_DIR=./data/logs
LOG_MAX_BYTES=1000000
LOG_VIEWER_PORT=8765

# --- Docker Compose overrides (uncomment when using docker compose up) ---
# OLLAMA_BASE_URL=http://ollama:11434
# EMBEDDING_PROVIDER=ollama
# CHROMA_PATH=/data/chroma
# LOG_DIR=/data/logs
